alias: "HQ - Routine B : Exécution et Auto-Désactivation v2"
description: Gère les pointes avec une logique de timestamp précise et se désactive seule.
trigger:
  - platform: template
    value_template: >-
      {{ states('input_datetime.hq_next_peak_start_0600') not in ['unknown',
      'unavailable'] and now() >=
      states('input_datetime.hq_next_peak_start_0600') | as_datetime | as_local
      }}
    id: start_0600
  - platform: time
    at: "10:00:00"
    id: end_1000
  - platform: template
    value_template: >-
      {{ states('input_datetime.hq_next_peak_start_1600') not in ['unknown',
      'unavailable'] and now() >=
      states('input_datetime.hq_next_peak_start_1600') | as_datetime | as_local
      }}
    id: start_1600
  - platform: time
    at: "20:00:00"
    id: end_2000
action:
  - choose:
      - conditions: "{{ trigger.id == 'start_0600' }}"
        sequence:
          - service: homeassistant.turn_off
            target:
              entity_id: light.remote_switch_fournaise_light_2
            data: {}
          - if:
              - condition: template
                value_template: "{{ is_state('input_boolean.chauffageplanchercuisine', 'on') }}"
            then:
              - service: switch.toggle
                target:
                  entity_id: switch.fingerbot_chauffage_switch
                data: {}
          - service: script.notification_generale
            data:
              message: Début de pointe HQ (06:00). Chauffage réduit.
      - conditions: >-
          {{ trigger.id == 'end_1000' and states('input_number.hq_count_06_09')
          | int > 0 }}
        sequence:
          - service: homeassistant.turn_on
            target:
              entity_id: light.remote_switch_fournaise_light_2
            data: {}
          - if:
              - condition: template
                value_template: >-
                  {{ is_state('input_boolean.chauffageplanchercuisine', 'off')
                  }}
            then:
              - service: switch.toggle
                target:
                  entity_id: switch.fingerbot_chauffage_switch
                data: {}
          - service: input_number.decrement
            target:
              entity_id: input_number.hq_count_06_09
            data: {}
          - service: script.notification_generale
            data:
              message: Fin de pointe HQ (10:00). Chauffage restauré.
      - conditions: "{{ trigger.id == 'start_1600' }}"
        sequence:
          - service: homeassistant.turn_off
            target:
              entity_id: light.remote_switch_fournaise_light_2
            data: {}
          - if:
              - condition: template
                value_template: "{{ is_state('input_boolean.chauffageplanchercuisine', 'on') }}"
            then:
              - service: switch.toggle
                target:
                  entity_id: switch.fingerbot_chauffage_switch
                data: {}
          - service: script.notification_generale
            data:
              message: Début de pointe HQ (16:00). Chauffage réduit.
      - conditions: >-
          {{ trigger.id == 'end_2000' and states('input_number.hq_count_16_20')
          | int > 0 }}
        sequence:
          - service: homeassistant.turn_on
            target:
              entity_id: light.remote_switch_fournaise_light_2
            data: {}
          - if:
              - condition: template
                value_template: >-
                  {{ is_state('input_boolean.chauffageplanchercuisine', 'off')
                  }}
            then:
              - service: switch.toggle
                target:
                  entity_id: switch.fingerbot_chauffage_switch
                data: {}
          - service: input_number.decrement
            target:
              entity_id: input_number.hq_count_16_20
            data: {}
          - service: script.notification_generale
            data:
              message: Fin de pointe HQ (20:00). Chauffage restauré.
  - if:
      - condition: template
        value_template: >-
          {{ states('input_number.hq_count_06_09')|int == 0 and
          states('input_number.hq_count_16_20')|int == 0 }}
    then:
      - service: automation.turn_off
        target:
          entity_id: automation.hq_routine_b_execution_et_auto_desactivation_v2
        data:
          stop_actions: true
mode: single
